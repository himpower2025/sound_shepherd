rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Shared Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // --- Users ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && incoming().keys().hasAll(['displayName', 'lastLogin'])
        && incoming().displayName is string
        && incoming().displayName.size() < 100;
    }

    // --- Songs ---
    match /songs/{songId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn()
        && incoming().createdBy == request.auth.uid
        && incoming().url is string
        && incoming().title is string;
      allow delete: if isSignedIn() && existing().createdBy == request.auth.uid;
    }

    // --- Presets ---
    match /users/{userId}/presets/{presetId} {
      allow list, get: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && incoming().songId is string
        && incoming().userId == userId;
      allow delete: if isOwner(userId);
    }
  }
}
